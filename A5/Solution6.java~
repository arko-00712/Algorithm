  static int bfs(int start, boolean[] visited){
    Queue<Integer> q = new ArrayDeque<Integer>();
    q.add(start);
    int c = 0;
    
    while(!q.isEmpty()){
      int x = q.poll();
      if(!visited[x]){
        visited[x] = true;
        c++;
      } 
    }
    return c;
