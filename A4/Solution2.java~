import java.util.*;

public class Solution2{
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int m = sc.nextInt();

        int[] u = new int[m];
        int[] v = new int[m];
        int[] w = new int[m];

        // read u
        for (int i = 0; i < m; i++) {
            u[i] = sc.nextInt();
        }

        // read v
        for (int i = 0; i < m; i++) {
            v[i] = sc.nextInt();
        }

        // read w
        for (int i = 0; i < m; i++) {
            w[i] = sc.nextInt();
        }

        // adjacency list using ArrayList
        ArrayList<ArrayList<String>> adj = new ArrayList<>();

        // initialize lists
        for (int i = 0; i <= n; i++) {
            adj.add(new ArrayList<>());
        }

        // build graph
        for (int i = 0; i < m; i++) {
            adj.get(u[i]).add("(" + v[i] + "," + w[i] + ")");
        }

        // print adjacency list
        for (int i = 1; i <= n; i++) {
            System.out.print(i + ":");

            for (String s : adj.get(i)) {
                System.out.print(" " + s);
            }

            System.out.println();
        }

        sc.close();
    }
}