import java.util.*;

public class Solution3easy {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        long x = sc.nextLong();

        long[] arr = new long[n];

        for(int i = 0; i < n; i++) {
            arr[i] = sc.nextLong();
        }

        // check every combination of 3 numbers
        for(int i = 0; i < n; i++) {
            for(int j = i + 1; j < n; j++) {
                for(int k = j + 1; k < n; k++) {

                    if(arr[i] + arr[j] + arr[k] == x) {
                        System.out.println((i+1) + " " + (j+1) + " " + (k+1));
                        return;
                    }

                }
            }
        }

        System.out.println(-1);
    }
}