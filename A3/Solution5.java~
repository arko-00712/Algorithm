import java.util.*;

public class Solution5 {

    static long modPow(long a, long n, long m) {
        long result = 1;
        a %= m;

        while (n > 0) {
            if (n % 2 == 1)
                result = (result * a) % m;

            a = (a * a) % m;
            n /= 2;
        }

        return result;
    }

    static long sum(long a, long n, long m) {
        if (n == 0) return 0;
        if (n == 1) return a % m;

        if (n % 2 == 0) {
            long half = sum(a, n / 2, m);
            long p = modPow(a, n / 2, m);
            return (half + (p * half) % m) % m;
        } 
        else {
            return (sum(a, n - 1, m) + modPow(a, n, m)) % m;
        }
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int T = sc.nextInt();

        while (T-- > 0) {

            long a = sc.nextLong();
            long n = sc.nextLong();
            long m = sc.nextLong();

            System.out.println(sum(a, n, m));
        }
    }
}